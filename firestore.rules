rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is the system administrator or has admin role
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Users collection - users can read/write their own profile, admin can read/write all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Products collection - any authenticated user can read, only admin can edit/write
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Orders collection - authenticated users can read, create and update; admin can delete
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // Profile fields collection - anyone authenticated can read, only admin can edit/write
    match /profile_fields/{fieldId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Metadata collection - authenticated users can read and write initialization flags
    match /metadata/{metadataId} {
      allow read, write: if request.auth != null;
    }

    // Settings collection - any authenticated user can read, only admin can write
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Stock alerts collection - authenticated users can read/create, only admins can delete
    match /stock_alerts/{alertId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }
  }
}

